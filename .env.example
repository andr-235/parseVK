# ==============================================
# БЕЗОПАСНАЯ КОНФИГУРАЦИЯ
# ==============================================
# Скопируйте этот файл в .env и заполните реальными значениями
# НИКОГДА не коммитьте .env в git!

# ---------------------------------------------
# DATABASE (PostgreSQL)
# ---------------------------------------------
POSTGRES_USER=your_secure_username
POSTGRES_PASSWORD=your_strong_password_min_16_chars
POSTGRES_DB=vk_api
DATABASE_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@db:5432/${POSTGRES_DB}?schema=public

# ---------------------------------------------
# REDIS
# ---------------------------------------------
REDIS_PASSWORD=your_redis_strong_password

# ---------------------------------------------
# VK API TOKEN
# ---------------------------------------------
# Получить: https://vkhost.github.io/
# Требуемые права: wall, groups, users, offline
VK_TOKEN=vk1.a.YOUR_TOKEN_HERE

# ---------------------------------------------
# MONITORING DATABASE (опционально)
# ---------------------------------------------
MONITOR_DATABASE_URL=

# ---------------------------------------------
# FRONTEND CONFIGURATION
# ---------------------------------------------
VITE_APP_TITLE=ВК Аналитик
VITE_API_URL=/api
VITE_API_WS_URL=auto
VITE_DEV_MODE=false
VITE_APP_VERSION=0.31.4

# ---------------------------------------------
# GRAFANA
# ---------------------------------------------
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=your_grafana_strong_password

# ---------------------------------------------
# CORS (опционально)
# ---------------------------------------------
CORS_ORIGINS=

# ---------------------------------------------
# NPM Registry (для Китая или прокси)
# ---------------------------------------------
NPM_REGISTRY=https://registry.npmmirror.com
NPM_REGISTRY_FALLBACK=https://registry.npmjs.org/
