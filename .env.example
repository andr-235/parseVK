# ==============================================
# БЕЗОПАСНАЯ КОНФИГУРАЦИЯ
# ==============================================
# Скопируйте этот файл в .env и заполните реальными значениями
# НИКОГДА не коммитьте .env в git!

# ---------------------------------------------
# FASTAPI MICROSERVICES: IDENTITY + GATEWAY
# ---------------------------------------------
IDENTITY_POSTGRES_USER=identity
IDENTITY_POSTGRES_PASSWORD=identity_dev_password_change_me
IDENTITY_POSTGRES_DB=identity
IDENTITY_ADMIN_USERNAME=admin
IDENTITY_ADMIN_PASSWORD=admin-change-me
IDENTITY_ADMIN_EMAIL=
FASTAPI_INTERNAL_SERVICE_TOKEN=replace-with-shared-internal-token
GATEWAY_REFRESH_COOKIE_NAME=refresh_token
GATEWAY_CSRF_COOKIE_NAME=csrf_token
GATEWAY_REFRESH_COOKIE_SECURE=false
GATEWAY_REFRESH_COOKIE_SAMESITE=lax
GATEWAY_ALLOWED_ORIGINS=["http://localhost:5173","http://127.0.0.1:5173","http://localhost:8080"]

# ---------------------------------------------
# FASTAPI MICROSERVICES: TASKS
# ---------------------------------------------
TASKS_POSTGRES_USER=tasks
TASKS_POSTGRES_PASSWORD=tasks_dev_password_change_me
TASKS_POSTGRES_DB=tasks
TASKS_OUTBOX_PUBLISH_ENABLED=true

# ---------------------------------------------
# FASTAPI MICROSERVICES: VK + CONTENT
# ---------------------------------------------
VK_SERVICE_POSTGRES_USER=vk
VK_SERVICE_POSTGRES_PASSWORD=vk_dev_password_change_me
VK_SERVICE_POSTGRES_DB=vk
VK_SERVICE_DATABASE_URL=postgresql+asyncpg://vk:vk_dev_password_change_me@vk-db:5432/vk
VK_SERVICE_KAFKA_CONSUMER_ENABLED=true
VK_SERVICE_OUTBOX_PUBLISH_ENABLED=true
VK_SERVICE_DEFAULT_GROUP_IDS=[1]
# Required for production. Service will fail fast on startup if missing.
VK_SERVICE_VK_TOKEN=

# ---------------------------------------------
# FASTAPI MICROSERVICES: MODERATION
# ---------------------------------------------
MODERATION_POSTGRES_USER=moderation
MODERATION_POSTGRES_PASSWORD=moderation_dev_password_change_me
MODERATION_POSTGRES_DB=moderation
MODERATION_KAFKA_CONSUMER_ENABLED=true

# ---------------------------------------------
# FASTAPI MICROSERVICES: IM (WhatsApp)
# ---------------------------------------------
IM_POSTGRES_USER=im
IM_POSTGRES_PASSWORD=im_dev_password_change_me
IM_POSTGRES_DB=im
IM_SERVICE_WAPPI_API_TOKEN=
IM_SERVICE_WAPPI_PROFILE_ID=
IM_SERVICE_MAX_PROFILE_ID=
IM_SERVICE_OUTBOX_PUBLISH_ENABLED=true
IM_SERVICE_KAFKA_CONSUMER_ENABLED=true

CONTENT_POSTGRES_USER=content
CONTENT_POSTGRES_PASSWORD=content_dev_password_change_me
CONTENT_POSTGRES_DB=content
CONTENT_DATABASE_URL=postgresql+asyncpg://content:content_dev_password_change_me@content-db:5432/content
CONTENT_KAFKA_CONSUMER_ENABLED=true
CONTENT_KAFKA_GROUP_VK=content-service
CONTENT_KAFKA_GROUP_IM=content-service-im
CONTENT_KAFKA_RETRY_MAX_ATTEMPTS=3
CONTENT_KAFKA_RETRY_BACKOFF_SECONDS=1
CONTENT_KAFKA_POISON_POLICY=pause
CONTENT_VK_SERVICE_BASE_URL=http://vk-service:8000
CONTENT_LOG_LEVEL=INFO

# ---------------------------------------------
# REDIS
# ---------------------------------------------
REDIS_PASSWORD=your_redis_strong_password

# ---------------------------------------------
# ---------------------------------------------
# PRODUCTION DOCKER (раскомментировать на сервере)
# ---------------------------------------------
# DOCKER_REGISTRY=ghcr.io
# DOCKER_NAMESPACE=andr-235
# VERSION=latest
# COMPOSE_FILE=docker-compose.yml;compose.production.yml

# ---------------------------------------------
# VK API TOKEN
# ---------------------------------------------
# Получить: https://vkhost.github.io/
# Требуемые права: wall, groups, users, offline
VK_TOKEN=vk1.a.YOUR_TOKEN_HERE

# ---------------------------------------------
# MONITORING DATABASE (опционально)
# ---------------------------------------------
MONITOR_DATABASE_URL=

# ---------------------------------------------
# FRONTEND CONFIGURATION
# ---------------------------------------------
VITE_APP_TITLE=ВК Аналитик
VITE_API_URL=/api
VITE_GATEWAY_API_URL=/api
VITE_API_WS_URL=auto
VITE_DEV_MODE=false
VITE_APP_VERSION=0.31.4

# ---------------------------------------------
# GRAFANA
# ---------------------------------------------
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=your_grafana_strong_password

# ---------------------------------------------
# CORS (опционально)
# ---------------------------------------------
CORS_ORIGINS=

# ---------------------------------------------
# NPM Registry (для Китая или прокси)
# ---------------------------------------------
NPM_REGISTRY=https://registry.npmmirror.com
NPM_REGISTRY_FALLBACK=https://registry.npmjs.org/

# ---------------------------------------------
# TELEGRAM SERVICE CONFIGURATION
# ---------------------------------------------
# Proxy URL for Telegram connection
VPN_SERVICE_TELEGRAM_URL=socks5://username:password@proxy_host:proxy_port
# Credentials from my.telegram.org
TELEGRAM_API_ID=123456
TELEGRAM_API_HASH=your_api_hash_value_here
# Optional credentials for Bot or Userbot authentication
TELEGRAM_BOT_TOKEN=your_bot_token_if_using_bot_auth
TELEGRAM_SESSION_STRING=your_string_session_if_using_userbot_auth

