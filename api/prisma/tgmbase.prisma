generator client {
  provider = "prisma-client"
  output   = "../src/generated/tgmbase"
}

datasource db {
  provider = "postgresql"
}

model channel {
  id                 BigInt    @id(map: "idx_16653_primary") @default(autoincrement())
  channel_id         BigInt    @unique(map: "idx_16653_channel_id")
  title              String
  date               DateTime  @db.Timestamp(6)
  scam               Boolean   @default(false)
  username           String?   @unique(map: "idx_16653_username") @db.VarChar(32)
  participants_count BigInt?
  region             Int       @default(0) @db.SmallInt
  description        String?   @db.VarChar(512)
  upd_date           DateTime? @db.Timestamptz(6)
}

model group {
  id                 BigInt   @id(map: "idx_16663_primary") @default(autoincrement())
  group_id           BigInt   @unique(map: "idx_16663_group_id")
  title              String
  participants_count BigInt?
  date               DateTime @db.Timestamp(6)
  region             Int      @default(0) @db.SmallInt
  description        String?  @db.VarChar(512)
  upd_date           DateTime @default(now()) @db.Timestamptz(6)
}

model keyword {
  id         BigInt @id(map: "idx_16673_primary") @default(autoincrement())
  word       String
  declension Int    @default(1) @db.SmallInt
  region     BigInt
}

model message {
  id         BigInt   @id(map: "idx_16681_primary") @default(autoincrement())
  message_id BigInt
  peer_id    BigInt
  date       DateTime @default(now()) @db.Timestamptz(6)
  message    String?
  from_id    BigInt?
  forwarded  Boolean? @default(false)
  reply_to   BigInt?
  media      Boolean? @default(false)
  keywords   String?
}

model snitch_admin {
  id         BigInt    @id(map: "idx_16689_primary") @default(autoincrement())
  login      String
  password   String
  last_login DateTime? @db.Timestamptz(6)
}

model supergroup {
  id                 BigInt   @id(map: "idx_16696_primary") @default(autoincrement())
  supergroup_id      BigInt   @unique(map: "idx_16696_supergroup_id")
  title              String
  username           String?  @unique(map: "idx_16696_username") @db.VarChar(32)
  participants_count BigInt?
  scam               Int      @db.SmallInt
  date               DateTime @db.Timestamp(6)
  region             Int      @default(0) @db.SmallInt
  description        String?  @db.VarChar(512)
  upd_date           DateTime @default(now()) @db.Timestamptz(6)
}

model telegramnotify {
  id          BigInt   @id(map: "idx_16707_primary") @default(autoincrement())
  telegram_id BigInt   @unique(map: "idx_16707_telegram_id")
  username    String   @db.VarChar(64)
  timestamp   DateTime @default(now()) @db.Timestamptz(6)
}

model user {
  id         BigInt    @id(map: "idx_16713_primary") @default(autoincrement())
  user_id    BigInt    @unique(map: "idx_16713_user_id")
  bot        Boolean   @default(false)
  scam       Boolean   @default(false)
  premium    Boolean   @default(false)
  first_name String?
  last_name  String?
  username   String?   @db.VarChar(32)
  phone      String?
  upd_date   DateTime? @db.Timestamptz(6)
  dlMatches   DlMatchResult[]
}

model DlImportBatch {
  id           BigInt         @id @default(autoincrement())
  status       String         @db.VarChar(32)
  filesTotal   Int            @default(0) @map("files_total")
  filesSuccess Int            @default(0) @map("files_success")
  filesFailed  Int            @default(0) @map("files_failed")
  createdAt    DateTime       @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime       @updatedAt @map("updated_at") @db.Timestamptz(6)
  files        DlImportFile[]

  @@index([createdAt(sort: Desc)])
  @@map("dl_import_batch")
}

model DlImportFile {
  id               BigInt          @id @default(autoincrement())
  batchId          BigInt          @map("batch_id")
  originalFileName String          @map("original_file_name") @db.VarChar(255)
  fileHash         String?         @map("file_hash") @db.VarChar(128)
  status           String          @db.VarChar(32)
  rowsTotal        Int             @default(0) @map("rows_total")
  rowsSuccess      Int             @default(0) @map("rows_success")
  rowsFailed       Int             @default(0) @map("rows_failed")
  error            String?         @db.Text
  isActive         Boolean         @default(false) @map("is_active")
  replacedFileId   BigInt?         @map("replaced_file_id")
  createdAt        DateTime        @default(now()) @map("created_at") @db.Timestamptz(6)
  finishedAt       DateTime?       @map("finished_at") @db.Timestamptz(6)
  updatedAt        DateTime        @updatedAt @map("updated_at") @db.Timestamptz(6)
  batch            DlImportBatch   @relation(fields: [batchId], references: [id], onDelete: Cascade)
  contacts         DlContact[]
  replacedFile     DlImportFile?   @relation("DlImportFileReplacement", fields: [replacedFileId], references: [id], onDelete: SetNull)
  replacingFiles   DlImportFile[]  @relation("DlImportFileReplacement")

  @@index([batchId, createdAt(sort: Desc)])
  @@index([originalFileName])
  @@index([isActive, createdAt(sort: Desc)])
  @@index([originalFileName, isActive])
  @@map("dl_import_file")
}

model DlContact {
  id              BigInt       @id @default(autoincrement())
  importFileId    BigInt       @map("import_file_id")
  telegramId      String?      @map("telegram_id") @db.Text
  username        String?      @db.Text
  phone           String?      @db.Text
  firstName       String?      @map("first_name") @db.Text
  lastName        String?      @map("last_name") @db.Text
  description     String?      @db.Text
  region          String?      @db.Text
  joinedAt        DateTime?    @map("joined_at") @db.Timestamptz(6)
  channelsRaw     String?      @map("channels_raw") @db.Text
  fullName        String?      @map("full_name") @db.Text
  address         String?      @db.Text
  vkUrl           String?      @map("vk_url") @db.Text
  email           String?      @db.Text
  telegramContact String?      @map("telegram_contact") @db.Text
  instagram       String?      @db.Text
  viber           String?      @db.Text
  odnoklassniki   String?      @db.Text
  birthDateText   String?      @map("birth_date_text") @db.Text
  usernameExtra   String?      @map("username_extra") @db.Text
  geo             String?      @db.Text
  sourceRowIndex  Int          @map("source_row_index")
  createdAt       DateTime     @default(now()) @map("created_at") @db.Timestamptz(6)
  importFile      DlImportFile @relation(fields: [importFileId], references: [id], onDelete: Cascade)
  matchResults    DlMatchResult[]

  @@index([importFileId, sourceRowIndex])
  @@index([telegramId])
  @@index([phone])
  @@index([username])
  @@map("dl_contact")
}

model DlMatchRun {
  id                  BigInt          @id @default(autoincrement())
  status              String          @db.VarChar(32)
  contactsTotal       Int             @default(0) @map("contacts_total")
  matchesTotal        Int             @default(0) @map("matches_total")
  strictMatchesTotal  Int             @default(0) @map("strict_matches_total")
  usernameMatchesTotal Int            @default(0) @map("username_matches_total")
  phoneMatchesTotal   Int             @default(0) @map("phone_matches_total")
  createdAt           DateTime        @default(now()) @map("created_at") @db.Timestamptz(6)
  finishedAt          DateTime?       @map("finished_at") @db.Timestamptz(6)
  error               String?         @db.Text
  results             DlMatchResult[]

  @@index([createdAt(sort: Desc)])
  @@map("dl_match_run")
}

model DlMatchResult {
  id                   BigInt       @id @default(autoincrement())
  runId                BigInt       @map("run_id")
  dlContactId          BigInt       @map("dl_contact_id")
  tgmbaseUserId        BigInt?      @map("tgmbase_user_id")
  strictTelegramIdMatch Boolean      @default(false) @map("strict_telegram_id_match")
  usernameMatch        Boolean      @default(false) @map("username_match")
  phoneMatch           Boolean      @default(false) @map("phone_match")
  dlContactSnapshot    Json         @map("dl_contact_snapshot")
  tgmbaseUserSnapshot   Json?        @map("tgmbase_user_snapshot")
  createdAt            DateTime     @default(now()) @map("created_at") @db.Timestamptz(6)
  run                  DlMatchRun   @relation(fields: [runId], references: [id], onDelete: Cascade)
  dlContact            DlContact    @relation(fields: [dlContactId], references: [id], onDelete: Cascade)
  tgmbaseUser          user?        @relation(fields: [tgmbaseUserId], references: [user_id], onDelete: SetNull)

  @@index([runId])
  @@index([dlContactId])
  @@index([tgmbaseUserId])
  @@index([runId, dlContactId])
  @@map("dl_match_result")
}
